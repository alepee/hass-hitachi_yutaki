{
  "dashboard": {
    "title": "Hitachi Yutaki — Fleet Overview",
    "uid": "hitachi-fleet-overview",
    "tags": ["hitachi-yutaki", "telemetry"],
    "timezone": "browser",
    "refresh": "1h",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Active Installations",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) FROM installations WHERE last_seen > NOW() - INTERVAL '7 days';",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "green", "value": 20 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Installations (All Time)",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) FROM installations;",
            "format": "table"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Metrics Points (24h)",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) FROM metrics WHERE time > NOW() - INTERVAL '24 hours';",
            "format": "table"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Daily Stats Reports (7d)",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) FROM daily_stats WHERE date > CURRENT_DATE - 7;",
            "format": "table"
          }
        ]
      },
      {
        "id": 5,
        "type": "piechart",
        "title": "Model Distribution",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT profile AS \"Model\", COUNT(*) AS \"Count\" FROM installations GROUP BY profile ORDER BY \"Count\" DESC;",
            "format": "table"
          }
        ]
      },
      {
        "id": 6,
        "type": "piechart",
        "title": "Gateway Distribution",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT gateway_type AS \"Gateway\", COUNT(*) AS \"Count\" FROM installations GROUP BY gateway_type ORDER BY \"Count\" DESC;",
            "format": "table"
          }
        ]
      },
      {
        "id": 7,
        "type": "piechart",
        "title": "Integration Version",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT integration_version AS \"Version\", COUNT(*) AS \"Count\" FROM installations GROUP BY integration_version ORDER BY \"Count\" DESC;",
            "format": "table"
          }
        ]
      },
      {
        "id": 8,
        "type": "table",
        "title": "Installations Detail",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT LEFT(instance_hash, 12) AS \"Hash\", profile AS \"Model\", gateway_type AS \"Gateway\", ha_version AS \"HA Version\", integration_version AS \"Int. Version\", power_supply AS \"Power\", has_dhw AS \"DHW\", has_pool AS \"Pool\", has_cooling AS \"Cooling\", max_circuits AS \"Circuits\", has_secondary_compressor AS \"2nd Comp.\", first_seen AS \"First Seen\", last_seen AS \"Last Seen\" FROM installations ORDER BY last_seen DESC;",
            "format": "table"
          }
        ]
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "New Installations Over Time",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "TigerData" },
        "targets": [
          {
            "rawSql": "SELECT date_trunc('day', first_seen) AS time, COUNT(*) AS \"New Installations\" FROM installations GROUP BY 1 ORDER BY 1;",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 50
            }
          }
        }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
